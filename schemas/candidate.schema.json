{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evozeus.dev/schemas/candidate.schema.json",
  "title": "EvoZeus Candidate",
  "type": "object",
  "required": [
    "id",
    "title",
    "type",
    "status",
    "source_session",
    "observed_behavior",
    "evidence",
    "pattern",
    "operational_rule",
    "when_to_use",
    "when_not_to_use",
    "counterexamples",
    "privacy_review"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^candidate-[a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 8 },
    "type": {
      "type": "string",
      "enum": ["skill", "factor", "pattern", "habit", "environment_rule", "report_template", "negative_pattern"]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "community", "reviewed", "core", "deprecated", "rejected"]
    },
    "source_session": { "type": "string", "minLength": 1 },
    "observed_behavior": { "type": "string", "minLength": 1 },
    "evidence": {
      "type": "object",
      "required": ["level", "summary"],
      "properties": {
        "level": { "type": "integer", "minimum": 0, "maximum": 5 },
        "summary": { "type": "string", "minLength": 1 },
        "artifacts": { "type": "array", "items": { "type": "string" } }
      }
    },
    "pattern": { "type": "string", "minLength": 1 },
    "operational_rule": { "type": "string", "minLength": 1 },
    "when_to_use": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "when_not_to_use": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "counterexamples": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "privacy_review": {
      "type": "object",
      "required": ["raw_logs_included", "secrets_removed", "private_paths_removed", "customer_data_removed"],
      "properties": {
        "raw_logs_included": { "type": "boolean", "const": false },
        "secrets_removed": { "type": "boolean", "const": true },
        "private_paths_removed": { "type": "boolean", "const": true },
        "customer_data_removed": { "type": "boolean", "const": true },
        "note": { "type": "string" }
      }
    }
  }
}
