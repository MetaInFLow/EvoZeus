{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "name": "evozeus-metainflow",
  "cleanUrls": false,
  "redirects": [
    {
      "source": "/",
      "destination": "/skill.md",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/skill.md",
      "destination": "/SKILL.md"
    }
  ],
  "headers": [
    {
      "source": "/skill.md",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/markdown; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
